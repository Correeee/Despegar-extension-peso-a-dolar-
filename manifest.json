{
  "manifest_version": 3,
  "name": "Despegar peso a dólar",
  "description": "Muestra el precio en dólares de los productos de Despegar.",
  "version": "1.0",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "images/icon-32.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.despegar.com/*",
    "https://www.despegar.com.ar/*"
  ],
  "content_scripts": [
    {
      "js": [
        "scripts/content.js"
      ],
      "matches": [
        "https://www.despegar.com/*",
        "https://www.despegar.com.ar/*"
      ],
      "exclude_matches": [
        "https://www.despegar.com.ar/trip/accommodations/detail/*",
        "https://www.despegar.com/trip/accommodations/detail/*",
        "https://www.despegar.com.ar/checkout/*",
        "https://www.despegar.com/checkout/*"
      ],
      "css": [
        "style/style.css"
      ]
    }
  ]
}
